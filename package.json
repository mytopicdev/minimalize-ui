{
  "name": "minimalize-ui",
  "private": false,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "main": "dist/minimalize-ui.cjs",
  "module": "dist/minimalize-ui.es.js",
  "unpkg": "dist/minimalize-ui.umd.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/minimalize-ui.es.js",
      "require": "./dist/minimalize-ui.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prepare": "pnpm run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.4",
    "path": "0.12.7",
    "tailwindcss": "4.2.4",
    "vite-plugin-dts": "4.5.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.9",
    "vite-plugin-css-injected-by-js": "5.0.1"
  },
  "peerDependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
